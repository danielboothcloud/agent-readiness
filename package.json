{
  "name": "@danielboothcloud/agent-readiness",
  "version": "0.1.5",
  "description": "Evaluate how prepared your codebase is for autonomous AI coding agents",
  "type": "module",
  "bin": {
    "agent-readiness": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "build": "tsup src/index.ts --format esm --target node20 --out-dir dist --clean --no-dts",
    "build:web": "pnpm --dir web install --frozen-lockfile && pnpm --dir web run build",
    "build:all": "pnpm run build && pnpm run build:web",
    "prepublishOnly": "pnpm run build:all",
    "dev:web": "pnpm --dir web install && pnpm --dir web run dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "agent",
    "readiness",
    "codebase",
    "evaluation",
    "cli",
    "kodus"
  ],
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ora": "^8.2.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
